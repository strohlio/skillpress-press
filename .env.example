# Required: your Anthropic API key (a pressing costs ~$0.10 of Opus)
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
# PRESS_MODEL=claude-opus-4-8
# SKILLS_DIR=/Users/you/.claude/skills
# WORK_DIR=./work
# MAX_SECONDS=1800
# Only needed for videos without captions (path to a whisper.cpp model):
# WHISPER_MODEL=/usr/local/share/whisper/ggml-base.en.bin
